# Copy this file to .env.local and fill in real values
# Never commit .env.local to git

# ── Java Spring Boot API (flood-service-community on port 4001) ───────────────
# Server-side Next.js API routes call this URL.
# Local dev: http://localhost:4001   |   Docker: http://community-api:4001
# Production: https://api.yourdomain.com
JAVA_API_URL=http://localhost:4001

# Browser-side auth calls — public-facing URL in production
NEXT_PUBLIC_JAVA_API_URL=http://localhost:4001

# ── Neon PostgreSQL ───────────────────────────────────────────────────────────
# Serverless Postgres — shared between both Java backend services and
# the Next.js BFF layer. Get from: console.neon.tech → your project → Connection string
# Always use the POOLED connection string (?sslmode=require&channel_binding=require)
DATABASE_URL=postgresql://neondb_owner:<password>@<host>/neondb?sslmode=require&channel_binding=require

# ── Upstash Redis ─────────────────────────────────────────────────────────────
# HTTP-based Redis cache for Next.js API routes (edge-compatible).
# Get from: console.upstash.com → your database → REST API
UPSTASH_REDIS_REST_URL=https://<your-db>.upstash.io
UPSTASH_REDIS_REST_TOKEN=<your-token>

# ── CRM URL (for admin redirect after login) ──────────────────────────────────
NEXT_PUBLIC_CRM_URL=http://localhost:3000

# ── Web Push Notifications (VAPID) ───────────────────────────────────────────
# Generate a key pair: npx web-push generate-vapid-keys
# PUBLIC key goes here (client-side). Keep VAPID_PRIVATE_KEY in Java backend only.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key_here

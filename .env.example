# ── flood-website-community — Environment Variables ──────────────────────────
# Copy this file to .env.local for local development.
# For Vercel: set these in Project → Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────────────────────

# ── Community Spring Boot API (flood-service-community) ──────────────────────
# NextAuth and /api/* routes call JAVA_API_URL server-side (BFF). Kong is not a
# substitute for the BFF — in Docker, point JAVA_API_URL at Kong so traffic matches prod:
#   JAVA_API_URL=http://kong-gateway:8000/community
# Host browser / mobile use PUBLIC_GATEWAY_HTTP (see deploy/.env.example); Next.js
# server in compose uses the internal kong hostname above.
# LOCAL (no Docker):  http://localhost:4001
# VERCEL + Railway:    https://flood-service-community-production.up.railway.app
JAVA_API_URL=https://flood-service-community-production.up.railway.app

# ── Neon PostgreSQL (direct DB access from Next.js API routes) ────────────────
# Copy connection string from Neon dashboard (use a strong password; never commit it).
# Example shape:
DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/neondb?sslmode=require

# ── Upstash Redis (server-side caching) ──────────────────────────────────────
# Get from: console.upstash.com → your database → REST API
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── CRM website URL (flood-website-crm) ──────────────────────────────────────
# Prefer CRM_URL (server-side, read at request time) over NEXT_PUBLIC_CRM_URL
# (baked into the JS bundle at build time, requires redeploy to update).
# LOCAL:   http://localhost:3000
# VERCEL:  https://flood-website-crm.vercel.app
CRM_URL=https://flood-website-crm.vercel.app
NEXT_PUBLIC_CRM_URL=https://flood-website-crm.vercel.app

# ── Google Maps ───────────────────────────────────────────────────────────────
# Restrict this key to your Vercel domain in Google Cloud Console
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# ── Web Push Notifications (VAPID) ───────────────────────────────────────────
# Public key only — keep the private key in the Java backend (flood-service-community)
# Generate: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# ── NextAuth.js ────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64url 32
# On Vercel, enable this variable for Production, Preview, and Development so build
# and runtime both see it. After changing AUTH_SECRET, redeploy and clear cookies
# (or use incognito) so old session tokens are not used.
AUTH_SECRET=
# Canonical URL of this deployment (set on Vercel so cookies/session work)
# Example: https://flood-website-community.vercel.app
AUTH_URL=
# Also set JAVA_API_URL (Spring API) in Vercel — must not be localhost.
